        "# The headline number: does L1 accuracy drop as k increases?\n",
        "\n",
        "print(f\"\\n{'k':>4}  {'n':>6}  {'L1 acc':>8}  {'peak layer':>10}  {'L32 acc':>8}\")\n",
        "print(\"-\" * 45)\n",
        "for k in hop_values:\n",
        "    accs  = acc_by_hop[k]\n",
        "    n     = int((hops==k).sum())\n",
        "    l1    = accs[0]\n",
        "    peak  = int(np.nanargmax(accs)) + 1\n",
        "    l32   = accs[31]\n",
        "    print(f\"{k:>4}  {n:>6}  {l1:>8.3f}  {peak:>10}  {l32:>8.3f}\")"
      ]
    },
