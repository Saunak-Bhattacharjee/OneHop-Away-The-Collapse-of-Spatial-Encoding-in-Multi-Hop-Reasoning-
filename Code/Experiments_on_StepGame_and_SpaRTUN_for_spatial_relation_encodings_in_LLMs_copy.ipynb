        "for k in hop_values:\n",
        "    accs  = acc_by_hop[k]\n",
        "    n     = int((hops==k).sum())\n",
        "    l1    = accs[0]\n",
        "    peak  = int(np.nanargmax(accs)) + 1\n",
        "    pkval = float(np.nanmax(accs))\n",
        "    l32   = accs[31]\n",
        "    above = \"YES\" if pkval > 0.30 else \"marginal\"\n",
